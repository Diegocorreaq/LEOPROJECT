generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id           String   @id @default(uuid())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          String
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Cliente {
  id          String            @id @default(uuid())
  razonSocial String
  ruc         String            @unique
  email       String?
  telefono    String?
  direccion   String?
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  servicios   ServicioCliente[]
  facturas    Factura[]
}

model PropietarioSubcontratado {
  id          String      @id @default(uuid())
  razonSocial String
  ruc         String      @unique
  contacto    String?
  telefono    String?
  vehiculos   Vehiculo[]
  conductores Conductor[]
}

model Vehiculo {
  id                         String                    @id @default(uuid())
  propietarioSubcontratadoId String?
  propietarioSubcontratado   PropietarioSubcontratado? @relation(fields: [propietarioSubcontratadoId], references: [id])
  placa                      String                    @unique
  placaCarreta               String?
  tipoUnidad                 String
  tipo                       String
  mtc                        String?
  mtcCarreta                 String?
  pesoNeto                   Decimal?
  pesoBruto                  Decimal?
  cargaUtil                  Decimal?
  estado                     String                    @default("ACTIVO")
  servicios                  Servicio[]
  docsVehiculo               DocVehiculo[]
  mantenimientos             MantenimientoKm[]
}

model Conductor {
  id                         String                    @id @default(uuid())
  propietarioSubcontratadoId String?
  propietarioSubcontratado   PropietarioSubcontratado? @relation(fields: [propietarioSubcontratadoId], references: [id])
  nombre                     String
  apPaterno                  String
  apMaterno                  String?
  tipoDocumento              String
  nroDocumento               String
  licencia                   String?
  tipo                       String
  activo                     Boolean                   @default(true)
  servicios                  Servicio[]
  liquidaciones              Liquidacion[]
  saldoMovimientos           LiquidacionSaldoMovimiento[]
}

model RutaTarifa {
  id          String          @id @default(uuid())
  codigoRuta  String
  origen      String
  destino     String
  descripcion String?
  tarifa1tn   Decimal?
  tarifa2tn   Decimal?
  tarifa5tn   Decimal?
  tarifa10tn  Decimal?
  tarifa30tn  Decimal?
  ordenes     OrdenServicio[]
}

model Ubigeo {
  codigo             String     @id
  distrito           String
  provinciaCodigo    String?    @map("provincia_codigo")
  provincia           String
  departamentoCodigo String?    @map("departamento_codigo")
  departamento        String
  etiqueta           String
  busqueda           String
  serviciosOrigen    Servicio[] @relation("ServicioOrigenUbigeo")
  serviciosDestino   Servicio[] @relation("ServicioDestinoUbigeo")

  @@map("ubigeo")
}

model Servicio {
  id                 String    @id @default(uuid())
  vehiculoId         String
  vehiculo           Vehiculo  @relation(fields: [vehiculoId], references: [id])
  conductorId        String
  conductor          Conductor @relation(fields: [conductorId], references: [id])
  fechaServicio      DateTime
  origen             String
  destino            String
  origenUbigeoCodigo String?
  destinoUbigeoCodigo String?
  origenUbigeo       Ubigeo?   @relation("ServicioOrigenUbigeo", fields: [origenUbigeoCodigo], references: [codigo])
  destinoUbigeo      Ubigeo?   @relation("ServicioDestinoUbigeo", fields: [destinoUbigeoCodigo], references: [codigo])
  estado             String    @default("PROGRAMADO")
  observaciones      String?
  createdAt          DateTime  @default(now())
  clientes           ServicioCliente[]
  guias              GuiaRemision[]
  liquidacion        Liquidacion?
  orden              OrdenServicio?
}

model ServicioCliente {
  id         String   @id @default(uuid())
  servicioId String
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  @@unique([servicioId, clienteId])
}

model GuiaRemision {
  id                          String               @id @default(uuid())
  servicioId                  String?
  servicio                    Servicio?            @relation(fields: [servicioId], references: [id])
  serie                       String
  numero                      String
  fechaEmision                DateTime
  horaEmision                 String?
  fechaInicioTraslado         DateTime?
  puntoDeSalida               String?
  puntoDeLlegada              String?
  remitenteNombre             String?
  remitenteRuc                String?
  destinatarioNombre          String?
  destinatarioRuc             String?
  pagadorFleteNombre          String?
  pagadorFleteRuc             String?
  transportistaNombre         String?
  transportistaRuc            String?
  placaPrincipal              String?
  placaSecundaria             String?
  conductorPrincipalNombre    String?
  conductorPrincipalDocumento String?
  conductorPrincipalLicencia  String?
  pesoBrutoTotal              Decimal?
  unidadPeso                  String?
  mtcNumero                   String?
  subcontratistaNombre        String?
  subcontratistaRuc           String?
  transbordo                  Boolean              @default(false)
  retornoVacio                Boolean              @default(false)
  subcontratado               Boolean              @default(false)
  estado                      String               @default("EN_TRANSITO")
  fechaRecepcion              DateTime?
  observaciones               String?
  observacionSunat            String?
  origenImportacion           String?
  nombreArchivoOrigen         String?
  rawPayload                  Json?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  bienes                      GuiaBien[]
  docsRelacionados            GuiaDocRelacionado[]

  @@unique([serie, numero])
  @@index([fechaEmision])
  @@index([estado])
  @@index([servicioId])
}

model GuiaBien {
  id              String       @id @default(uuid())
  guiaRemisionId  String
  guiaRemision    GuiaRemision @relation(fields: [guiaRemisionId], references: [id])
  descripcion     String
  cantidad        Decimal?
  unidadMedida    String?
  cantidadKg      Decimal?
  bienNormalizado String?
  codigoSunat     String?
}

model GuiaDocRelacionado {
  id                String       @id @default(uuid())
  guiaRemisionId    String
  guiaRemision      GuiaRemision @relation(fields: [guiaRemisionId], references: [id])
  tipoDocumentoCode String?
  tipoDocumento     String
  numeroDocumento   String
  rucEmisor         String?
}

model Liquidacion {
  id                    String                       @id @default(uuid())
  servicioId            String?                      @unique
  servicio              Servicio?                    @relation(fields: [servicioId], references: [id])
  conductorId           String
  conductor             Conductor                    @relation(fields: [conductorId], references: [id])
  montoEntregado        Decimal                      @default(0)
  viaticos              Decimal                      @default(0)
  peajes                Decimal                      @default(0)
  combustible           Decimal                      @default(0)
  galones               Decimal                      @default(0)
  kmInicial             Decimal?
  kmFinal               Decimal?
  otros                 Decimal                      @default(0)
  totalGastos           Decimal                      @default(0)
  saldo                 Decimal                      @default(0)
  detalleSaldo          String?
  status                String                       @default("PENDIENTE")
  observaciones         String?
  createdAt             DateTime                     @default(now())
  comprobantes          LiquidacionComprobante[]
  saldoMovimientosOrigen LiquidacionSaldoMovimiento[] @relation("LiquidacionSaldoOrigen")
  saldoMovimientosDestino LiquidacionSaldoMovimiento[] @relation("LiquidacionSaldoDestino")
}

model LiquidacionComprobante {
  id            String      @id @default(uuid())
  liquidacionId String
  liquidacion   Liquidacion @relation(fields: [liquidacionId], references: [id])
  tipo          String
  numero        String?
  descripcion   String?
  monto         Decimal
  urlArchivo    String?
  createdAt     DateTime    @default(now())
}

model LiquidacionSaldoMovimiento {
  id                  String      @id @default(uuid())
  liquidacionOrigenId String
  liquidacionOrigen   Liquidacion @relation("LiquidacionSaldoOrigen", fields: [liquidacionOrigenId], references: [id])
  liquidacionDestinoId String?
  liquidacionDestino  Liquidacion? @relation("LiquidacionSaldoDestino", fields: [liquidacionDestinoId], references: [id])
  conductorId         String
  conductor           Conductor   @relation(fields: [conductorId], references: [id])
  tipo                String
  monto               Decimal
  fechaMovimiento     DateTime    @default(now())
  observacion         String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([liquidacionOrigenId])
  @@index([liquidacionDestinoId])
  @@index([conductorId])
  @@index([fechaMovimiento])
}

model OrdenServicio {
  id                String      @id @default(uuid())
  servicioId        String      @unique
  servicio          Servicio    @relation(fields: [servicioId], references: [id])
  rutaTarifaId      String?
  rutaTarifa        RutaTarifa? @relation(fields: [rutaTarifaId], references: [id])
  numero            String?
  fleteNeto         Decimal     @default(0)
  igv               Decimal     @default(0)
  total             Decimal     @default(0)
  fleteTercero      Decimal     @default(0)
  incluyeIgv        Boolean     @default(true)
  detraccion        Decimal     @default(0)
  estado            String      @default("PENDIENTE")
  fechaEnvioCliente DateTime?
  fechaSelloCliente DateTime?
  createdAt         DateTime    @default(now())
  facturas          Factura[]
}

model Factura {
  id                   String         @id @default(uuid())
  ordenServicioId      String?
  ordenServicio        OrdenServicio? @relation(fields: [ordenServicioId], references: [id])
  clienteId            String
  cliente              Cliente        @relation(fields: [clienteId], references: [id])
  serie                String
  numero               String
  tipo                 String
  fechaEmision         DateTime
  fechaVencimiento     DateTime?
  moneda               String?
  montoNeto            Decimal        @default(0)
  igv                  Decimal        @default(0)
  total                Decimal        @default(0)
  detraccionPorcentaje Decimal        @default(0)
  detraccionMonto      Decimal        @default(0)
  estadoPago           String         @default("PENDIENTE")
  formaPago            String?
  origenImportacion    String?
  nombreArchivoOrigen  String?
  rawPayload           Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  guias                FacturaGuia[]
  pagos                Pago[]

  @@unique([serie, numero])
}

model FacturaGuia {
  id         String   @id @default(uuid())
  facturaId  String
  factura    Factura  @relation(fields: [facturaId], references: [id])
  serieGuia  String
  numeroGuia String
  createdAt  DateTime @default(now())

  @@unique([facturaId, serieGuia, numeroGuia])
}

model Pago {
  id              String   @id @default(uuid())
  facturaId       String
  factura         Factura  @relation(fields: [facturaId], references: [id])
  fechaPago       DateTime
  monto           Decimal
  medioPago       String?
  numeroOperacion String?
  cuentaBancaria  String?
  identificado    Boolean  @default(false)
  observacion     String?
  createdAt       DateTime @default(now())
}

model LibroCompras {
  id              String    @id @default(uuid())
  numeroFactura   String
  proveedorNombre String?
  proveedorRuc    String?
  fechaEmision    DateTime?
  montoNeto       Decimal   @default(0)
  igv             Decimal   @default(0)
  total           Decimal   @default(0)
  concepto        String?
  estado          String    @default("PENDIENTE")
  createdAt       DateTime  @default(now())
}

model DocVehiculo {
  id               String    @id @default(uuid())
  vehiculoId       String
  vehiculo         Vehiculo  @relation(fields: [vehiculoId], references: [id])
  tipoDoc          String
  fechaVencimiento DateTime?
  fechaAnterior    DateTime?
  observacion      String?
  updatedAt        DateTime  @updatedAt

  @@unique([vehiculoId, tipoDoc])
}

model MantenimientoKm {
  id                  String   @id @default(uuid())
  vehiculoId          String
  vehiculo            Vehiculo @relation(fields: [vehiculoId], references: [id])
  componente          String
  kmPermitido         Decimal  @default(0)
  kmAcumulado         Decimal  @default(0)
  rendimientoEstandar Decimal  @default(0)
  updatedAt           DateTime @updatedAt

  @@unique([vehiculoId, componente])
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  actorRole  String?
  requestId  String?
  method     String?
  path       String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([requestId])
  @@index([actorId, createdAt])
}
