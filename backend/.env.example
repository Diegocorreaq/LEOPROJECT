PORT=3000
NODE_ENV=development

DATABASE_URL=
JWT_SECRET=

# Lista exacta de origenes permitidos, separados por coma.
# En local normalmente basta con http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Cookies de autenticacion.
# COOKIE_SAME_SITE=none requiere COOKIE_SECURE=true
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# false = backend solo API
# true = Express sirve frontend/dist si existe
SERVE_FRONTEND=false

LOG_LEVEL=info

# Seed del administrador inicial
# Debe tener al menos 12 caracteres.
# SEED_ADMIN_EMAIL=admin@tuempresa.com
# SEED_ADMIN_NOMBRE=Administrador
# SEED_ADMIN_PASSWORD=CambiaMeAhora123!
