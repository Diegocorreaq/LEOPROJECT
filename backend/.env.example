# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Grupo Leo Backend
# Copia este archivo a .env y completa los valores ANTES de ejecutar la app.
# NUNCA subas el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ──────────────────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:tu_password_aqui@localhost:5432/grupo_leo_db"

# ── JWT Secret ────────────────────────────────────────────────────────────
# OBLIGATORIO: mínimo 32 caracteres aleatorios.
# Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REEMPLAZA_CON_AL_MENOS_64_CARACTERES_ALEATORIOS_AQUI_EJEMPLO_xyz123"

# ── Servidor ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS — orígenes permitidos (separados por coma) ──────────────────────
# Desarrollo: frontend Vite
# Producción: dominio real de la app (ej: https://app.grupleo.com)
ALLOWED_ORIGINS="http://localhost:5173"

# ── Cookies ───────────────────────────────────────────────────────────────
# En producción, establecer en true para que las cookies solo viajen por HTTPS
COOKIE_SECURE=false

# ── Logging ───────────────────────────────────────────────────────────────
# Niveles: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Seed de usuario inicial (SOLO para primer setup) ─────────────────────
# Ejecutar: SEED_ADMIN_PASSWORD="TuContraseña123!" npm run seed
# O agregar aquí y ejecutar: npm run seed
# SEED_ADMIN_EMAIL="admin@tuempresa.com"
# SEED_ADMIN_NOMBRE="Administrador"
# SEED_ADMIN_PASSWORD="CambiaMeAhora123!"
