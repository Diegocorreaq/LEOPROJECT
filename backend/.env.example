DATABASE_URL="postgresql://postgres:tu_password_aqui@localhost:5432/grupo_leo_db"

# Minimo 32 caracteres aleatorios.
JWT_SECRET="REEMPLAZA_CON_AL_MENOS_64_CARACTERES_ALEATORIOS"

PORT=3000
NODE_ENV=development

# Debe incluir el origen exacto del frontend.
# Tambien se usa para validacion CSRF explicita en requests mutantes autenticados por cookie.
ALLOWED_ORIGINS="http://localhost:5173"

# En produccion debe ser true.
COOKIE_SECURE=false

LOG_LEVEL=info

# Seed del administrador inicial
# Debe tener al menos 12 caracteres.
# SEED_ADMIN_EMAIL="admin@tuempresa.com"
# SEED_ADMIN_NOMBRE="Administrador"
# SEED_ADMIN_PASSWORD="CambiaMeAhora123!"
